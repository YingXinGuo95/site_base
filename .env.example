# Auth.js v5 — generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Supabase PostgreSQL — Project Settings > Database > Connection string (Pooler)
DATABASE_URL=

# Tenant identifier — shared tables are isolated by this value (RLS)
TENANT_ID=saas_base
